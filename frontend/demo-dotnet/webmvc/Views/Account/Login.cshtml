@model webmvc.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <h1 class="mb-4">Login</h1>

        <form asp-action="Login" method="post" novalidate data-testid="login-form">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" data-testid="login-error"></div>

            <div class="mb-3">
                <label asp-for="Username" class="form-label">Username</label>
                <input asp-for="Username" class="form-control" data-testid="username-field" autocomplete="username" />
                <span asp-validation-for="Username" class="text-danger" data-testid="username-error"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label">Password</label>
                <input asp-for="Password" type="password" class="form-control" data-testid="password-field" autocomplete="current-password" />
                <span asp-validation-for="Password" class="text-danger" data-testid="password-error"></span>
            </div>

            <button type="submit" class="btn btn-primary" data-testid="login-button">Login</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
